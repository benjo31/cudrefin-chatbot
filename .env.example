     1|PORT=3001
     2|PUBLIC_BASE_URL=http://localhost:3001
     3|
     4|# Stockage
     5|DATABASE_PATH=./data/cudrefin.db
     6|UPLOADS_PATH=./data/uploads
     7|
     8|# Sécurité
     9|# Génère via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
    10|MASTER_KEY=replace-with-64-hex-chars
    11|SESSION_SECRET=replace-with-a-long-random-string
    12|
    13|# Compte admin par défaut (créé par `npm run seed`)
